{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "tasks": {
    "prepack": {
      "dependsOn": ["^prepack"],
      "outputs": ["build/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**"]
    },
    "lint": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "check": {
      "dependsOn": [],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "serve": {
      "cache": false,
      "persistent": true
    }
  },
  "envMode": "loose"
}
