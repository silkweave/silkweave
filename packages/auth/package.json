{
  "name": "@silkweave/auth",
  "version": "1.7.0",
  "description": "Silkweave Auth - Bearer token and OAuth 2.1 support for MCP servers",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/silkweave/silkweave.git",
    "directory": "packages/auth"
  },
  "type": "module",
  "main": "src/index.ts",
  "publishConfig": {
    "main": "build/index.mjs",
    "exports": {
      ".": "./build/index.mjs"
    },
    "types": "./build/index.d.ts"
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "watch": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "check": "pnpm lint && pnpm typecheck"
  },
  "dependencies": {
    "@silkweave/core": "workspace:*",
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.0.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
