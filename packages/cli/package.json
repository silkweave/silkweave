{
  "name": "@silkweave/cli",
  "version": "1.3.0",
  "description": "Silkweave CLI Adapter",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/silkweave/silkweave.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "clean": "rimraf build",
    "build": "tsup",
    "prepack": "pnpm clean && pnpm build",
    "watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "check": "pnpm lint && pnpm typecheck"
  },
  "dependencies": {
    "@silkweave/core": "workspace:*",
    "@silkweave/logger": "workspace:*",
    "@clack/prompts": "^1.0.1",
    "change-case": "^5.4.4",
    "commander": "^13.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.0.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
