{
  "name": "silkweave",
  "version": "1.4.1",
  "description": "Silkweave Umbrella Package",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/silkweave/silkweave.git",
    "directory": "packages/silkweave"
  },
  "type": "module",
  "exports": {
    "./auth": {
      "types": "./build/auth.d.mts",
      "default": "./build/auth.mjs"
    },
    "./cli": {
      "types": "./build/cli.d.mts",
      "default": "./build/cli.mjs"
    },
    "./core": {
      "types": "./build/core.d.mts",
      "default": "./build/core.mjs"
    },
    "./fastify": {
      "types": "./build/fastify.d.mts",
      "default": "./build/fastify.mjs"
    },
    "./logger": {
      "types": "./build/logger.d.mts",
      "default": "./build/logger.mjs"
    },
    "./mcp": {
      "types": "./build/mcp.d.mts",
      "default": "./build/mcp.mjs"
    },
    "./typegen": {
      "types": "./build/typegen.d.mts",
      "default": "./build/typegen.mjs"
    },
    "./vercel": {
      "types": "./build/vercel.d.mts",
      "default": "./build/vercel.mjs"
    }
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "watch": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "check": "pnpm lint && pnpm typecheck"
  },
  "dependencies": {
    "@silkweave/auth": "workspace:*",
    "@silkweave/cli": "workspace:*",
    "@silkweave/core": "workspace:*",
    "@silkweave/fastify": "workspace:*",
    "@silkweave/logger": "workspace:*",
    "@silkweave/mcp": "workspace:*",
    "@silkweave/typegen": "workspace:*",
    "@silkweave/vercel": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.0.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
