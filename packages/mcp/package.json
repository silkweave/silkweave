{
  "name": "@silkweave/mcp",
  "version": "1.5.0",
  "description": "Silkweave MCP Package",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/silkweave/silkweave.git",
    "directory": "packages/mcp"
  },
  "type": "module",
  "main": "src/index.ts",
  "publishConfig": {
    "main": "build/index.mjs",
    "exports": {
      ".": "./build/index.mjs"
    },
    "types": "./build/index.d.ts"
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "watch": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "check": "pnpm lint && pnpm typecheck"
  },
  "dependencies": {
    "@silkweave/auth": "workspace:*",
    "@silkweave/core": "workspace:*",
    "@silkweave/logger": "workspace:*",
    "@clack/prompts": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "change-case": "^5.4.4",
    "commander": "^13.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
