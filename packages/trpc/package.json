{
  "name": "@silkweave/trpc",
  "version": "1.7.0",
  "description": "Silkweave tRPC Adapter",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/silkweave/silkweave.git",
    "directory": "packages/trpc"
  },
  "type": "module",
  "main": "src/index.ts",
  "publishConfig": {
    "main": "build/index.mjs",
    "exports": {
      ".": "./build/index.mjs"
    },
    "types": "./build/index.d.ts"
  },
  "scripts": {
    "clean": "rimraf build",
    "build": "tsdown",
    "prepack": "pnpm clean && pnpm build",
    "watch": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "check": "pnpm lint && pnpm typecheck"
  },
  "dependencies": {
    "@silkweave/auth": "workspace:*",
    "@silkweave/core": "workspace:*",
    "@silkweave/logger": "workspace:*",
    "@trpc/server": "^11.7.1",
    "change-case": "^5.4.4",
    "cors": "^2.8.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@trpc/client": "^11.7.1",
    "@types/cors": "^2.8.19",
    "@types/node": "^22.0.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
