---
import Layout from './Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title?: string
}

const { title = 'Documentation - Silkweave' } = Astro.props

const sections = [
  { id: 'getting-started', label: 'Getting Started', children: [
    { id: 'installation', label: 'Installation' },
    { id: 'quick-start', label: 'Quick Start' }
  ]},
  { id: 'core-concepts', label: 'Core Concepts', children: [
    { id: 'actions', label: 'Actions' },
    { id: 'adapters', label: 'Adapters' },
    { id: 'context', label: 'Context & DI' }
  ]},
  { id: 'adapter-reference', label: 'Adapter Reference', children: [
    { id: 'adapter-mcp-stdio', label: 'MCP (stdio)' },
    { id: 'adapter-mcp-http', label: 'MCP (HTTP)' },
    { id: 'adapter-fastify', label: 'Fastify REST' },
    { id: 'adapter-trpc', label: 'tRPC' },
    { id: 'adapter-cli', label: 'CLI' },
    { id: 'adapter-vercel', label: 'Vercel Serverless' },
    { id: 'adapter-typegen', label: 'Type Generation' }
  ]},
  { id: 'smart-tool-results', label: 'Smart Tool Results', children: [
    { id: 'custom-tool-result', label: 'Custom toolResult Hook' },
    { id: 'result-utilities', label: 'Result Utilities' }
  ]},
  { id: 'authentication', label: 'Authentication', children: [
    { id: 'bearer-token', label: 'Bearer Token' },
    { id: 'oauth', label: 'OAuth 2.1' },
    { id: 'per-action-guards', label: 'Per-Action Guards' }
  ]},
  { id: 'error-handling', label: 'Error Handling', children: [
    { id: 'silkweave-error', label: 'SilkweaveError' },
    { id: 'adapter-error-behavior', label: 'Adapter Behavior' }
  ]},
  { id: 'testing', label: 'Testing', children: [
    { id: 'unit-testing', label: 'Unit Testing Actions' }
  ]},
  { id: 'escape-hatches', label: 'Escape Hatches', children: [
    { id: 'native-objects', label: 'Accessing Native Objects' },
    { id: 'context-by-adapter', label: 'Context by Adapter' }
  ]}
]
---

<Layout title={title}>
  <Nav />
  <div class="docs-wrapper">
    <aside class="docs-sidebar">
      <nav class="docs-nav">
        {sections.map(section => (
          <div class="nav-group">
            <a href={`#${section.id}`} class="nav-group-title">{section.label}</a>
            <ul>
              {section.children.map(child => (
                <li><a href={`#${child.id}`} class="nav-link" data-section={child.id}>{child.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>
    <main class="docs-content">
      <slot />
    </main>
  </div>
  <Footer />
</Layout>

<style>
  .docs-wrapper {
    display: flex;
    max-width: 1100px;
    margin: 0 auto;
    padding: 6rem 1.5rem 0;
    gap: 3rem;
  }

  .docs-sidebar {
    position: sticky;
    top: 5rem;
    width: 220px;
    flex-shrink: 0;
    height: calc(100vh - 5rem);
    overflow-y: auto;
    padding: 1rem 0;
  }

  .docs-sidebar::-webkit-scrollbar {
    width: 4px;
  }

  .docs-sidebar::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 2px;
  }

  .docs-content {
    flex: 1;
    min-width: 0;
    padding-bottom: 4rem;
  }

  .nav-group {
    margin-bottom: 1.25rem;
  }

  .nav-group-title {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
    padding: 0.2rem 0;
  }

  .nav-group-title:hover {
    color: var(--text);
  }

  .nav-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-link {
    display: block;
    font-size: 0.85rem;
    color: var(--text-dim);
    padding: 0.2rem 0 0.2rem 0.75rem;
    border-left: 2px solid transparent;
    transition: all 0.15s;
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--text);
  }

  .nav-link.active {
    color: var(--accent);
    border-left-color: var(--accent);
  }

  @media (max-width: 860px) {
    .docs-wrapper {
      flex-direction: column;
      padding-top: 5rem;
    }

    .docs-sidebar {
      position: relative;
      top: 0;
      width: 100%;
      height: auto;
      border-bottom: 1px solid var(--border);
      padding-bottom: 1rem;
    }

    .docs-nav {
      display: flex;
      gap: 1.5rem;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .nav-group {
      margin-bottom: 0;
      flex-shrink: 0;
    }

    .nav-group ul {
      display: flex;
      gap: 0.5rem;
    }

    .nav-link {
      border-left: none;
      padding: 0.2rem 0.5rem;
      white-space: nowrap;
    }

    .nav-link.active {
      border-left: none;
      background: var(--accent-bg);
      border-radius: var(--radius-sm);
    }
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.nav-link[data-section]')
  const sections = Array.from(links).map(link => {
    const id = link.getAttribute('data-section')!
    return { link, el: document.getElementById(id) }
  }).filter(s => s.el)

  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (entry.isIntersecting) {
        links.forEach(l => l.classList.remove('active'))
        const match = sections.find(s => s.el === entry.target)
        if (match) match.link.classList.add('active')
      }
    }
  }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 })

  sections.forEach(s => observer.observe(s.el!))
</script>
