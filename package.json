{
  "name": "silkweave",
  "private": true,
  "description": "Silkweave Toolkit",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/silkweave/silkweave.git"
  },
  "scripts": {
    "mcp": "cd example && pnpm tsx src/stdio.ts",
    "build": "turbo build",
    "lint": "turbo lint",
    "roam": "roam index && roam fitness && roam rules --ci",
    "check": "turbo check && pnpm roam",
    "clean": "turbo clean && rimraf .turbo/cache",
    "prepack": "turbo prepack",
    "publish:all": "pnpm publish -r --access public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "25.0.3",
    "rimraf": "^6.1.2",
    "turbo": "^2.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "overrides": {
    "@types/node": "25.0.3",
    "esbuild": "0.21.5",
    "typescript": "5.9.3",
    "vite": "7.3.0",
    "zod": "4.3.6"
  },
  "packageManager": "pnpm@10.33.0"
}
